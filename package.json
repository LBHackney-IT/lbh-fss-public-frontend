{
  "name": "lbh-fss-public-frontend",
  "version": "1.0.0",
  "license": "MIT",
  "main": "index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --verbose --maxWorkers=2 --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --ci --coverage",
    "format": "prettier --write \"./**\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"./**\" --ignore-path .prettierignore",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "php:lint": "composer run php:lint",
    "php:lint:ci": "composer run php:lint:ci",
    "php:format": "composer run php:format",
    "mock-api": "node ./mock-api/app.js",
    "dev": "concurrently \"yarn start\" \"yarn mock-api\"",
    "mock-gen:categories": "node ./scripts/generateMockCategories.js",
    "mock-gen:demographic": "node ./scripts/generateMockDemographic.js",
    "mock-gen:services": "node ./scripts/generateMockServices.js"
  },
  "dependencies": {
    "@changey/react-leaflet-markercluster": "^4.0.0-rc1",
    "@fortawesome/fontawesome-free": "^6.5.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/pro-duotone-svg-icons": "^7.2.0",
    "@fortawesome/pro-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@sentry/react": "^9.46.0",
    "axios": "^1.16.0",
    "jest-junit": "^17.0.0",
    "lbh-frontend": "^4.0.0",
    "leaflet": "^1.9.4",
    "leaflet-gesture-handling": "^1.1.8",
    "lodash": "^4.18.1",
    "polished": "^4.3.1",
    "postcode-validator": "^3.10.11",
    "prop-types": "^15.8.1",
    "qs": "^6.12.0",
    "react": "^18.2.0",
    "react-accessible-accordion": "^5.0.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.72.0",
    "react-leaflet": "^4.2.1",
    "react-responsive": "^9.0.2",
    "react-router-dom": "^6.30.4",
    "react-share": "^5.3.0",
    "react-to-print": "^2.15.1",
    "react-toastify": "^10.0.6",
    "styled-components": "^5.3.11",
    "styled-components-breakpoint": "^3.0.0-preview.20",
    "styled-react-modal": "^3.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@faker-js/faker": "^8.4.0",
    "@hackney/prettier-config": "^1.0.1",
    "@sentry/vite-plugin": "^3.3.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.0",
    "@vitejs/plugin-react": "^5.2.0",
    "audit-ci": "^7.1.0",
    "babel-jest": "^30.3.0",
    "browserslist": "^4.28.2",
    "browserslist-to-esbuild": "^2.1.1",
    "concurrently": "^10.0.3",
    "connect-api-mocker": "^1.9.0",
    "core-js": "^3.49.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "express": "^5.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.2.0",
    "sass": "^1.98.0",
    "vite": "^7.3.5"
  },
  "resolutions": {
    "lodash": ">=4.18.1",
    "path-to-regexp": ">=8.4.0",
    "esbuild": ">=0.28.1"
  },
  "lint-staged": {
    "*.{js,jsx,json,css,md,yaml,yml}": [
      "prettier --write --ignore-path .prettierignore"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ],
    "wordpress/**/*.php": [
      "./.pre-commit/phpcbf-staged.sh"
    ]
  }
}
