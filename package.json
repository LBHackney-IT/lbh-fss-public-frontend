{
  "name": "lbh-fss-public-frontend",
  "version": "1.0.0",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:watch": "react-scripts test --watch",
    "test:ci": "react-scripts test --ci --coverage --reporters=jest-junit",
    "test:coverage": "react-scripts test --ci --coverage",
    "eject": "react-scripts eject",
    "format": "prettier --write \"./**\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"./**\" --ignore-path .prettierignore",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "mock-api": "node ./mock-api/app.js",
    "dev": "concurrently \"yarn start\" \"yarn mock-api\"",
    "mock-gen:categories": "node ./scripts/generateMockCategories.js",
    "mock-gen:demographic": "node ./scripts/generateMockDemographic.js",
    "mock-gen:services": "node ./scripts/generateMockServices.js"
  },
  "dependencies": {
    "@changey/react-leaflet-markercluster": "^4.0.0-rc1",
    "@fortawesome/fontawesome-free": "^6.5.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/pro-duotone-svg-icons": "^7.2.0",
    "@fortawesome/pro-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "axios": "^1.6.0",
    "http-proxy-middleware": "^2.0.6",
    "jest-junit": "^16.0.0",
    "lbh-frontend": "^3.5.3",
    "leaflet": "^1.9.4",
    "leaflet-gesture-handling": "^1.1.8",
    "lodash": "^4.17.21",
    "polished": "^4.3.1",
    "postcode-validator": "^3.1.0",
    "prop-types": "^15.8.1",
    "qs": "^6.12.0",
    "react": "^18.2.0",
    "react-accessible-accordion": "^5.0.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "react-leaflet": "^4.2.1",
    "react-responsive": "^9.0.2",
    "react-router-dom": "^6.30.3",
    "react-share": "^5.1.0",
    "react-to-print": "^2.15.1",
    "react-toastify": "^10.0.4",
    "styled-components": "^5.3.11",
    "styled-components-breakpoint": "^3.0.0-preview.20",
    "styled-components-modifiers": "^1.2.5",
    "styled-react-modal": "^3.0.1"
  },
  "browserslist": "> 1%, last 2 versions",
  "devDependencies": {
    "@babel/eslint-parser": "^7.24.0",
    "@faker-js/faker": "^8.4.0",
    "@hackney/prettier-config": "^1.0.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.0",
    "audit-ci": "^7.1.0",
    "concurrently": "^9.2.1",
    "connect-api-mocker": "^1.9.0",
    "core-js": "^3.37.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.0",
    "eslint-plugin-react": "^7.34.0",
    "express": "^4.19.0",
    "prettier": "^3.2.0",
    "react-scripts": "^5.0.1",
    "sass": "^1.97.3"
  },
  "lint-staged": {
    "*.{js,jsx,json,css,md,yaml,yml}": [
      "prettier --write --ignore-path .prettierignore"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "!src/index.js",
      "!src/serviceWorker.js",
      "!src/setupProxy.js"
    ]
  }
}
