VITE_MAPBOX_ACCESS_TOKEN=

# Build mode: use `yarn build --mode production|staging|development` so import.meta.env.PROD
# and MODE match the target (CircleCI/Makefile pass --mode from the deploy environment).
#
# Sentry: DSN in src/instrument.js; init only when import.meta.env.PROD (i.e. --mode production).
# https://docs.sentry.io/platforms/javascript/guides/react/
# Optional: release identifier (e.g. git SHA) for matching source maps
VITE_SENTRY_RELEASE=

# For production builds: upload source maps (set in CI secrets, not in Vite env files)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
